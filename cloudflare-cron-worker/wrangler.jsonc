{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "buttervote-cron-worker",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-12",
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    }
  },
  "triggers": {
    "crons": ["* * * * *"]
  },
  "vars": {
    "APP_URL": "https://buttervote.com"
  }
}
